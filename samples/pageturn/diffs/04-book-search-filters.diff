+@router.get("/search/advanced", response_model=dict)
+def advanced_search(
+    q: str = Query(..., min_length=1, description="Search query"),
+    genre: str | None = Query(None),
+    sort_by: str = Query("relevance", description="Sort by: relevance, price, year, title"),
+    order: str = Query("asc", description="Sort order: asc or desc"),
+    user: str = Depends(_get_current_user),
+):
+    """Advanced search with sorting and relevance scoring."""
+    q_lower = q.lower()
+    results = []
+    for b in _books.values():
+        score = 0
+        if q_lower in b.title.lower():
+            score += 2
+        if q_lower in b.author.lower():
+            score += 1
+        if score > 0:
+            results.append({"book": b, "score": score})
+
+    if sort_by == "relevance":
+        results.sort(key=lambda x: x["score"], reverse=(order == "desc"))
+    elif sort_by == "price":
+        results.sort(key=lambda x: x["book"].price, reverse=(order == "desc"))
+    elif sort_by == "year":
+        results.sort(key=lambda x: x["book"].year, reverse=(order == "desc"))
+    elif sort_by == "title":
+        results.sort(key=lambda x: x["book"].title.lower(), reverse=(order == "desc"))
+
+    return {
+        "query": q,
+        "total": len(results),
+        "results": results,
+    }
