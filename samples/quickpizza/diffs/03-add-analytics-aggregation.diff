@@ -0,0 +1,45 @@
+package analytics
+
+import (
+	"context"
+
+	"github.com/jackc/pgx/v5/pgxpool"
+)
+
+// Service provides analytics aggregation queries.
+type Service struct {
+	db *pgxpool.Pool
+}
+
+// NewService creates an analytics service.
+func NewService(db *pgxpool.Pool) *Service {
+	return &Service{db: db}
+}
+
+// IngredientStat holds ingredient usage data.
+type IngredientStat struct {
+	Name  string
+	Count int
+}
+
+// GetIngredientPopularity returns the most-used ingredients.
+func (s *Service) GetIngredientPopularity(ctx context.Context, limit int, period string) ([]IngredientStat, int, error) {
+	// Query: SELECT ingredient, COUNT(*) FROM pizza_ingredients
+	//        JOIN pizzas ON ... WHERE created_at > NOW() - interval
+	//        GROUP BY ingredient ORDER BY COUNT(*) DESC LIMIT $1
+	// This is an aggregation query that scans potentially large tables.
+	rows, err := s.db.Query(ctx, `
+		SELECT i.name, COUNT(*) as cnt
+		FROM pizza_ingredients pi
+		JOIN ingredients i ON i.id = pi.ingredient_id
+		JOIN pizzas p ON p.id = pi.pizza_id
+		WHERE p.created_at > NOW() - $2::interval
+		GROUP BY i.name
+		ORDER BY cnt DESC
+		LIMIT $1`, limit, period)
+	if err != nil {
+		return nil, 0, err
+	}
+	defer rows.Close()
+
+	// ... row scanning omitted for brevity
+	return nil, 0, nil
+}
