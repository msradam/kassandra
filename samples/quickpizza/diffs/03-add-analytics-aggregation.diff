@@ -0,0 +1,112 @@
+package api
+
+import (
+	"encoding/json"
+	"net/http"
+	"strconv"
+
+	"github.com/grafana/quickpizza/internal/analytics"
+)
+
+// IngredientAnalyticsResponse contains popularity data for ingredients.
+type IngredientAnalyticsResponse struct {
+	TopIngredients []IngredientStat `json:"top_ingredients"`
+	TotalPizzas    int              `json:"total_pizzas"`
+	Period         string           `json:"period"`
+}
+
+// IngredientStat is an ingredient with its usage count and percentage.
+type IngredientStat struct {
+	Name       string  `json:"name"`
+	Count      int     `json:"count"`
+	Percentage float64 `json:"percentage"`
+}
+
+// RatingAnalyticsResponse contains aggregated rating statistics.
+type RatingAnalyticsResponse struct {
+	AverageRating  float64          `json:"average_rating"`
+	TotalRatings   int              `json:"total_ratings"`
+	Distribution   []RatingBucket   `json:"distribution"`
+	TopRated       []TopRatedPizza  `json:"top_rated"`
+	Period         string           `json:"period"`
+}
+
+// RatingBucket groups ratings by star value.
+type RatingBucket struct {
+	Stars int     `json:"stars"`
+	Count int     `json:"count"`
+	Pct   float64 `json:"percentage"`
+}
+
+// TopRatedPizza is a pizza with its average rating.
+type TopRatedPizza struct {
+	Name          string  `json:"name"`
+	AverageRating float64 `json:"average_rating"`
+	RatingCount   int     `json:"rating_count"`
+}
+
+// handleIngredientAnalytics returns ingredient popularity data.
+// Performs aggregation query across all pizzas — can be slow on large datasets.
+// Query params: limit (default 10), period (7d, 30d, 90d; default 30d)
+func (s *Server) handleIngredientAnalytics(w http.ResponseWriter, r *http.Request) {
+	limit := 10
+	if l := r.URL.Query().Get("limit"); l != "" {
+		parsed, err := strconv.Atoi(l)
+		if err != nil || parsed < 1 || parsed > 100 {
+			http.Error(w, "limit must be between 1 and 100", http.StatusBadRequest)
+			return
+		}
+		limit = parsed
+	}
+
+	period := r.URL.Query().Get("period")
+	if period == "" {
+		period = "30d"
+	}
+	if period != "7d" && period != "30d" && period != "90d" {
+		http.Error(w, "period must be 7d, 30d, or 90d", http.StatusBadRequest)
+		return
+	}
+
+	stats, totalPizzas, err := s.analyticsService.GetIngredientPopularity(r.Context(), limit, period)
+	if err != nil {
+		s.logger.Error("ingredient analytics failed", "error", err)
+		http.Error(w, "internal server error", http.StatusInternalServerError)
+		return
+	}
+
+	items := make([]IngredientStat, len(stats))
+	for i, st := range stats {
+		items[i] = IngredientStat{
+			Name:       st.Name,
+			Count:      st.Count,
+			Percentage: float64(st.Count) / float64(totalPizzas) * 100,
+		}
+	}
+
+	resp := IngredientAnalyticsResponse{
+		TopIngredients: items,
+		TotalPizzas:    totalPizzas,
+		Period:         period,
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(resp)
+}
+
+// handleRatingAnalytics returns aggregated rating statistics.
+// Performs GROUP BY and AVG queries — read-heavy, may be slow.
+// Query params: period (7d, 30d, 90d; default 30d), top (default 5)
+func (s *Server) handleRatingAnalytics(w http.ResponseWriter, r *http.Request) {
+	period := r.URL.Query().Get("period")
+	if period == "" {
+		period = "30d"
+	}
+
+	topN := 5
+	if t := r.URL.Query().Get("top"); t != "" {
+		parsed, err := strconv.Atoi(t)
+		if err != nil || parsed < 1 || parsed > 50 {
+			http.Error(w, "top must be between 1 and 50", http.StatusBadRequest)
+			return
+		}
+		topN = parsed
+	}
+
+	result, err := s.analyticsService.GetRatingStats(r.Context(), period, topN)
+	if err != nil {
+		s.logger.Error("rating analytics failed", "error", err)
+		http.Error(w, "internal server error", http.StatusInternalServerError)
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(result)
+}
