diff --git a/internal/api/batch_handler.go b/internal/api/batch_handler.go
new file mode 100644
index 0000000..a7c3e1f
--- /dev/null
+++ b/internal/api/batch_handler.go
@@ -0,0 +1,98 @@
+package api
+
+import (
+	"encoding/json"
+	"fmt"
+	"net/http"
+	"sync"
+
+	"github.com/grafana/quickpizza/internal/pizza"
+)
+
+// BatchRecommendRequest holds multiple recommendation requests.
+type BatchRecommendRequest struct {
+	Requests []pizza.RecommendRequest `json:"requests"`
+}
+
+// BatchRecommendResponse holds the aggregated results.
+type BatchRecommendResponse struct {
+	Results []BatchResultItem `json:"results"`
+	Total   int               `json:"total"`
+	Errors  int               `json:"errors"`
+}
+
+// BatchResultItem is a single result or error in the batch.
+type BatchResultItem struct {
+	Index  int               `json:"index"`
+	Pizza  *pizza.Pizza      `json:"pizza,omitempty"`
+	Error  string            `json:"error,omitempty"`
+}
+
+// handleBatchRecommendPizza processes multiple pizza recommendation requests
+// in a single API call. Each sub-request is processed independently;
+// individual failures do not abort the batch.
+func (s *Server) handleBatchRecommendPizza(w http.ResponseWriter, r *http.Request) {
+	var req BatchRecommendRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		http.Error(w, fmt.Sprintf("invalid request body: %v", err), http.StatusBadRequest)
+		return
+	}
+
+	if len(req.Requests) == 0 {
+		http.Error(w, "requests array must not be empty", http.StatusBadRequest)
+		return
+	}
+
+	if len(req.Requests) > 100 {
+		http.Error(w, "batch size exceeds maximum of 100", http.StatusBadRequest)
+		return
+	}
+
+	results := make([]BatchResultItem, len(req.Requests))
+	var wg sync.WaitGroup
+	var mu sync.Mutex
+	errCount := 0
+
+	for i, subReq := range req.Requests {
+		wg.Add(1)
+		go func(idx int, sr pizza.RecommendRequest) {
+			defer wg.Done()
+
+			recommended, err := s.pizzaService.Recommend(r.Context(), sr)
+			if err != nil {
+				mu.Lock()
+				errCount++
+				mu.Unlock()
+				results[idx] = BatchResultItem{
+					Index: idx,
+					Error: err.Error(),
+				}
+				return
+			}
+
+			results[idx] = BatchResultItem{
+				Index: idx,
+				Pizza: recommended,
+			}
+		}(i, subReq)
+	}
+
+	wg.Wait()
+
+	resp := BatchRecommendResponse{
+		Results: results,
+		Total:   len(req.Requests),
+		Errors:  errCount,
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(http.StatusOK)
+	if err := json.NewEncoder(w).Encode(resp); err != nil {
+		s.logger.Error("failed to encode batch response", "error", err)
+	}
+}
