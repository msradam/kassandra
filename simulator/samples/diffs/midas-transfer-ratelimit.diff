+# ── Rate Limiting ──
+
+_rate_limits = {}
+
+def check_rate_limit(user_id: int, max_per_minute: int = 10):
+    """Simple in-memory rate limiter."""
+    import time
+    now = time.time()
+    key = f"{user_id}"
+    history = _rate_limits.get(key, [])
+    history = [t for t in history if now - t < 60]
+    if len(history) >= max_per_minute:
+        raise HTTPException(429, "Rate limit exceeded")
+    history.append(now)
+    _rate_limits[key] = history
+
